    "text": "#333333",
    "textSecondary": "#666666",
    "border": "#A0522D",
    "shadow": "rgba(0, 0, 0, 0.1)",
    "gradientStart": "#87CEEB",
    "gradientEnd": "#1E90FF"
  },
  "typography": {
